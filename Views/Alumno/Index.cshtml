@{
    Layout = null;
}
@model AlumnoViewModel

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

<style>
    :root {
        --primary: rgb(83,149,255);
        --primary-dark: rgb(60,120,220);
    }

    .logout-container {
        position: fixed;
        top: 15px;
        padding: 20px;
        right: 20px;
        z-index: 999;
    }

    .btn-logout {
        background: rgb(60,120,220);
        border: none;
        color: white;
        backdrop-filter: blur(6px);
        border-radius: 50%;
        padding: 10px 12px;
        font-size: 16px;
        transition: 0.3s;
    }

        .btn-logout:hover {
            background: rgba(255,255,255,0.4);
            transform: scale(1.1);
        }

    body {
        background: linear-gradient(135deg,var(--primary),#8ec5ff);
        font-family: 'Segoe UI',sans-serif;
    }

    .glass {
        background: rgba(255,255,255,0.9);
        backdrop-filter: blur(10px);
        border-radius: 20px;
        animation: fadeIn .6s ease;
    }

    .table {
        border-radius: 10px;
        overflow: hidden;
    }

    .badge-aprobado {
        background: #28a745;
    }

    .badge-reprobado {
        background: #dc3545;
    }

    @@keyframes fadeIn {
        from {
            opacity: 0;
            transform: translateY(20px)
        }

        to {
            opacity: 1;
            transform: translateY(0)
        }
    }
</style>
<!-- LOGOUT FIJO -->
<div class="logout-container">
    <form method="post" asp-controller="Admin" asp-action="Logout">
        <button type="submit" class="btn btn-logout">
            <i class="bi bi-box-arrow-right">Cerrar Sesión</i>
        </button>
    </form>
</div>
<div class="container mt-5">

    <!-- INFO ALUMNO -->
    <div class="glass p-4 shadow mb-4">


        <h3 class="fw-bold">@Model.Nombre </h3>

        <p class="mb-0">
            <strong>Grupo:</strong>
            <span class="badge bg-primary">@Model.Grupo</span>
        </p>

    </div>

    <!-- TABLA CALIFICACIONES -->
    <div class="glass p-4 shadow">

        <h5 class="mb-3">Calificaciones</h5>

        <table class="table table-hover align-middle text-center">

            <thead class="table-light">
                <tr>
                    <th>Materia</th>
                    <th>P1</th>
                    <th>P2</th>
                    <th>P3</th>
                    <th>Final</th>
                </tr>
            </thead>

            <tbody>

                @foreach (var c in Model.Calificaciones)
                {
                    var aprobado = c.Final >= 6;

                    <tr>
                        <td class="fw-semibold">@c.Materia?.Nombre</td>

                        <td>@c.Parcial1</td>
                        <td>@c.Parcial2</td>
                        <td>@c.Parcial3</td>

                        <td>
                            <span class="badge @(aprobado ? "badge-aprobado" : "badge-reprobado")">
                                @c.Final
                            </span>
                        </td>

                    </tr>
                }

            </tbody>

        </table>

    </div>

</div>