@{
    Layout = null;
}
@model piuttec.Models.DocenteViewModel

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

<style>
    :root {
        --primary: rgb(83,149,255);
        --primary-dark: rgb(60,120,220);
    }

    .logout-container {
        position: fixed;
        top: 15px;
        right: 20px;
        padding: 20px;
        z-index: 999;
    }

    .btn-logout {
        background: rgb(60,120,220);
        border: none;
        color: white;
        backdrop-filter: blur(6px);
        border-radius: 50%;
        padding: 10px 12px;
        font-size: 16px;
        transition: 0.3s;
    }

        .btn-logout:hover {
            background: rgba(255,255,255,0.4);
            transform: scale(1.1);
        }

    body {
        background: linear-gradient(135deg,var(--primary),#8ec5ff);
        font-family: 'Segoe UI',sans-serif;
    }

    .glass {
        background: rgba(255,255,255,0.9);
        backdrop-filter: blur(10px);
        border-radius: 20px;
        animation: fadeIn .6s ease;
    }

    .card-custom {
        border: none;
        border-radius: 18px;
        overflow: hidden;
    }

    .card-header {
        background: var(--primary);
        color: white;
        font-weight: bold;
    }

    .btn-custom {
        background: var(--primary);
        border: none;
        color: white;
        font-weight: 600;
        border-radius: 10px;
    }

        .btn-custom:hover {
            background: var(--primary-dark);
            transform: scale(1.05);
        }

    .list-group-item {
        border: none;
        border-radius: 10px;
        margin-bottom: 5px;
    }

    @@keyframes fadeIn {
        from {
            opacity: 0;
            transform: translateY(20px)
        }

        to {
            opacity: 1;
            transform: translateY(0)
        }
    }
</style>
<!-- LOGOUT FIJO -->
<div class="logout-container">
    <form method="post" asp-controller="Admin" asp-action="Logout">
        <button type="submit" class="btn btn-logout">
            <i class="bi bi-box-arrow-right">Cerrar Sesión</i>
        </button>
    </form>
</div>
<div class="container mt-5">

    <!-- HEADER -->
    <div class="glass p-4 shadow mb-4">
        <h3 class="fw-bold">Bienvenido, @Model.Nombre </h3>


    </div>

    <!-- MATERIAS -->
    <div class="glass p-4 shadow mb-4">
        <h5 class="mb-3">Materias a cargo</h5>

        <ul class="list-group">
            @foreach (var materia in ViewBag.Materias)
            {
                <li class="list-group-item shadow-sm">
                    📘 @materia.Nombre
                </li>
            }
        </ul>
    </div>

    <!-- FORMULARIOS -->
    <h5 class="text-white mb-3">Registrar calificaciones</h5>

    @foreach (var materia in ViewBag.Materias)
    {
        <div class="card card-custom shadow mb-4">

            <div class="card-header">
                @materia.Nombre
            </div>

            <div class="card-body">

                <form method="post" asp-action="RegistrarCalificacion">

                    <input type="hidden" name="MateriaId" value="@materia.Id" />
                    <input type="hidden" name="DocenteId" value="@ViewBag.DocenteId" />

                    <!-- Alumno -->
                    <div class="mb-3">
                        <label class="fw-semibold">Alumno</label>
                        <select name="AlumnoId" class="form-select">

                            @foreach (var c in ViewBag.AlumnosPorMateria)
                            {
                                if (c.MateriaId == materia.Id)
                                {
                                    <option value="@c.AlumnoId">
                                        @c.Alumno.Nombre
                                    </option>
                                }
                            }

                        </select>
                    </div>

                    <!-- Calificaciones -->
                    <div class="row g-2">

                        <div class="col">
                            <input type="number" step="0.01" name="Parcial1" class="form-control" placeholder="P1" />
                        </div>

                        <div class="col">
                            <input type="number" step="0.01" name="Parcial2" class="form-control" placeholder="P2" />
                        </div>

                        <div class="col">
                            <input type="number" step="0.01" name="Parcial3" class="form-control" placeholder="P3" />
                        </div>

                        <div class="col">
                            <input type="number" step="0.01" name="Final" class="form-control" placeholder="Final" />
                        </div>

                    </div>

                    <button class="btn btn-custom mt-3 w-100">
                        Guardar Calificación
                    </button>

                </form>

            </div>

        </div>
    }

</div>