@{
    Layout = null;
}
@model object

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

<style>
    :root {
        --primary: rgb(83,149,255);
        --primary-dark: rgb(60,120,220);
    }

    .logout-container {
        position: fixed;
        top: 15px;
        right: 20px;
        z-index: 999;
        padding: 20px;
    }

    .btn-logout {
        background: rgb(60,120,220);
        border: none;
        color: white;
        backdrop-filter: blur(6px);
        border-radius: 50%;
        padding: 10px 12px;
        font-size: 1px;
        transition: 0.3s;
    }

        .btn-logout:hover {
            background: rgba(255,255,255,0.4);
            transform: scale(1.1);
        }

    body {
        background: linear-gradient(135deg,var(--primary),#8ec5ff);
        font-family: 'Segoe UI',sans-serif;
    }

    .glass {
        background: rgba(255,255,255,0.9);
        backdrop-filter: blur(10px);
        border-radius: 18px;
        animation: fadeIn .6s ease;
    }

    .btn-custom {
        background: var(--primary);
        border: none;
        color: white;
        font-weight: 600;
        border-radius: 8px;
    }

        .btn-custom:hover {
            background: var(--primary-dark);
        }

    .table {
        border-radius: 10px;
        overflow: hidden;
    }

    @@keyframes fadeIn {
        from {
            opacity: 0;
            transform: translateY(20px)
        }

        to {
            opacity: 1;
            transform: translateY(0)
        }
    }
</style>

<!-- LOGOUT FIJO -->
<div class="logout-container">
    <form method="post" asp-controller="Admin" asp-action="Logout">
        <button type="submit" class="btn btn-logout">
            <i class="bi bi-box-arrow-right">Cerrar Sesión</i>
        </button>
    </form>
</div>
<div class="container mt-4">

    <h2 class="text-white mb-4">Panel Administrador</h2>


    <div class="row g-4">

        <!-- Registrar Usuario -->
        <div class="col-md-6">
            <div class="glass p-4 shadow">

                <h5 class="mb-3">Registrar Usuario</h5>

                <form method="post" asp-action="RegistrarUsuario">

                    <div class="mb-2">
                        <input class="form-control" name="nombre" placeholder="Nombre" required>
                    </div>

                    <div class="mb-2">
                        <input class="form-control" name="correo" placeholder="Correo" type="email" required>
                    </div>

                    <div class="mb-2">
                        <select class="form-control" name="rol">
                            <option value="Alumno">Alumno</option>
                            <option value="Docente">Docente</option>
                            <option value="Admin">Admin</option>
                        </select>
                    </div>

                    <div class="mb-3">
                        <input class="form-control" name="contrasena" placeholder="Contraseña" required>
                    </div>

                    <button class="btn btn-custom w-100">Registrar</button>

                </form>

            </div>
        </div>

        <!-- Registrar Materia -->
        <div class="col-md-6">
            <div class="glass p-4 shadow">

                <h5 class="mb-3">Registrar Materia</h5>

                <form method="post" asp-action="RegistrarMateria">

                    <div class="mb-3">
                        <input class="form-control" name="nombre" placeholder="Nombre Materia" required>
                    </div>

                    <button class="btn btn-custom w-100">Registrar</button>

                </form>

            </div>
        </div>

        <!-- Registrar Grupo -->
        <div class="col-md-6">
            <div class="glass p-4 shadow">

                <h5 class="mb-3">Registrar Grupo</h5>

                <form method="post" asp-action="RegistrarGrupo">

                    <div class="mb-3">
                        <input class="form-control" name="nombre" placeholder="Nombre Grupo" required>
                    </div>

                    <button class="btn btn-custom w-100">Registrar</button>

                </form>

            </div>
        </div>

        <!-- Asignar Alumno a Grupo -->
        <div class="col-md-6">
            <div class="glass p-4 shadow">

                <h5 class="mb-3">Asignar Alumno a Grupo</h5>

                <form method="post" asp-action="AsignarAlumnoGrupo">

                    <div class="mb-2">
                        <select class="form-control" name="alumnoId">
                            @foreach (var a in ViewBag.Alumnos)
                            {
                                <option value="@a.Id">@a.Nombre</option>
                            }
                        </select>
                    </div>

                    <div class="mb-3">
                        <select class="form-control" name="grupoId">
                            @foreach (var g in ViewBag.Grupos)
                            {
                                <option value="@g.Id">@g.Nombre</option>
                            }
                        </select>
                    </div>

                    <button class="btn btn-custom w-100">Asignar</button>

                </form>

            </div>
        </div>

        <!-- Asignar Materia a Alumno -->
        <div class="col-md-6">
            <div class="glass p-4 shadow">

                <h5 class="mb-3">Asignar Materia a Alumno</h5>

                <form method="post" asp-action="AsignarMateriaAlumno">

                    <div class="mb-2">
                        <select class="form-control" name="alumnoId">
                            @foreach (var a in ViewBag.Alumnos)
                            {
                                <option value="@a.Id">@a.Nombre</option>
                            }
                        </select>
                    </div>

                    <div class="mb-3">
                        <select class="form-control" name="materiaId">
                            @foreach (var m in ViewBag.Materias)
                            {
                                <option value="@m.Id">@m.Nombre</option>
                            }
                        </select>
                    </div>

                    <button class="btn btn-custom w-100">Asignar</button>

                </form>

            </div>
        </div>

        <!-- Asignar Docente -->
        <div class="col-md-6">
            <div class="glass p-4 shadow">

                <h5 class="mb-3">Asignar Docente a Materia</h5>

                <form method="post" asp-action="AsignarDocenteMateria">

                    <div class="mb-2">
                        <select class="form-control" name="docenteId">
                            @foreach (var d in ViewBag.Docentes)
                            {
                                <option value="@d.Id">@d.Nombre</option>
                            }
                        </select>
                    </div>

                    <div class="mb-3">
                        <select class="form-control" name="materiaId">
                            @foreach (var m in ViewBag.Materias)
                            {
                                <option value="@m.Id">@m.Nombre</option>
                            }
                        </select>
                    </div>

                    <button class="btn btn-custom w-100">Asignar</button>

                </form>

            </div>
        </div>

    </div>

    <!-- TABLA USUARIOS -->

    <div class="glass p-4 shadow mt-4">

        <h5 class="mb-3">Usuarios Registrados</h5>

        <table class="table table-hover align-middle">

            <thead class="table-light">
                <tr>
                    <th>ID</th>
                    <th>Nombre</th>
                    <th>Rol</th>
                    <th>Acciones</th>
                </tr>
            </thead>

            <tbody>

                @foreach (var u in ViewBag.Usuarios)
                {
                    <tr>

                        <td>@u.Id</td>
                        <td>@u.Nombre</td>
                        <td>@u.Rol</td>

                        <td>
                            <a class="btn btn-warning btn-sm" href="/Admin/EditarUsuario/@u.Id">Editar</a>
                            <a class="btn btn-danger btn-sm" href="/Admin/EliminarUsuario/@u.Id">Eliminar</a>
                        </td>

                    </tr>
                }

            </tbody>

        </table>

    </div>

</div>